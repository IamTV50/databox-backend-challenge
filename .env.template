# Databox ingestion API key (x-api-key header). Required.
DATABOX_API_KEY=

# Optional override for the Databox API base URL. Defaults to https://api.databox.com.
# DATABOX_BASE_URL=


# --- GitHub (PAT auth) -------------------------------------------------------

# GitHub personal access token. Scopes: read:org, public_repo (or repo). Required.
GITHUB_TOKEN=
# Organization whose repos are pulled (e.g. databox). Required.
GITHUB_ORG=
# Databox dataset id for the GitHub repos dataset. Required.
GITHUB_REPOS_DATASET_ID=


# --- GitLab (OAuth2 auth) ----------------------------------------------------
#
# First-time setup — do steps 1→4 in order:
#
#   1. Go to https://gitlab.com/-/profile/applications and create an
#      application. Set:
#         - Redirect URI:  http://127.0.0.1:4567/callback
#         - Scopes:        read_api  (this is enough; do NOT tick "api")
#      Save; GitLab shows you an Application ID and a Secret — copy both.
#
#   2. Fill GITLAB_CLIENT_ID, GITLAB_CLIENT_SECRET, GITLAB_REDIRECT_URI,
#      GITLAB_PROJECT_URL, and GITLAB_PROJECT_STATS_DATASET_ID below.
#
#   3. Run the bootstrap CLI to obtain a refresh token:
#         npm run oauth:gitlab
#      It opens a browser, you approve, and it prints a line like
#      `GITLAB_REFRESH_TOKEN=...`. Paste that value into this file.
#
#   4. Re-run step 3 whenever you restart the Node process before an
#      ingestion call. GitLab rotates refresh tokens on every refresh, and
#      the rotated value is kept only in process memory — see
#      docs/tradeoffs.md for why we don't rewrite .env at runtime and what a
#      production-ready fix looks like.

# Full URL of the project you want to track (e.g. https://gitlab.com/fdroid/fdroidclient).
# Works for nested groups too (e.g. https://gitlab.com/group/subgroup/project). Required.
GITLAB_PROJECT_URL=

# OAuth2 Application ID and Secret from step 1 above. Required.
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Must match the redirect URI registered on the OAuth app in step 1. The
# bootstrap CLI listens on this URL's port. Required.
GITLAB_REDIRECT_URI=http://127.0.0.1:4567/callback

# Produced by `npm run oauth:gitlab` (step 3). Required.
GITLAB_REFRESH_TOKEN=

# Databox dataset id for the GitLab project-stats dataset. Required.
GITLAB_PROJECT_STATS_DATASET_ID=
