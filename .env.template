# Full setup instructions live in README.md → "Running locally".
# This file is only a quick reference for the vars themselves.

# --- Databox -----------------------------------------------------------------

# Ingestion API key (x-api-key header).
DATABOX_API_KEY=

# Optional override. Defaults to https://api.databox.com.
# DATABOX_BASE_URL=


# --- GitHub (bearer / PAT) ---------------------------------------------------

# Personal access token with scopes: read:org, public_repo (or repo).
GITHUB_TOKEN=

# Organization whose repos are pulled (e.g. databox).
GITHUB_ORG=

# Databox dataset id for the github/repos dataset.
GITHUB_REPOS_DATASET_ID=


# --- GitLab (OAuth2) ---------------------------------------------------------

# Full URL of the project to track. Nested groups are fine.
# e.g. https://gitlab.com/fdroid/fdroidclient
GITLAB_PROJECT_URL=

# From the GitLab OAuth application (Application ID + Secret).
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Must match the redirect URI registered on the OAuth app.
# The bootstrap CLI listens on this URL's port.
GITLAB_REDIRECT_URI=http://127.0.0.1:4567/callback

# Produced by `npm run oauth:gitlab`. Rotates on every refresh —
# re-run the bootstrap before each fresh process start.
GITLAB_REFRESH_TOKEN=

# Databox dataset id for the gitlab/project-stats dataset.
GITLAB_PROJECT_STATS_DATASET_ID=
