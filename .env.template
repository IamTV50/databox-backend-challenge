# Databox ingestion API key (x-api-key header). Required.
DATABOX_API_KEY=

# Optional override for the Databox API base URL. Defaults to https://api.databox.com.
# DATABOX_BASE_URL=

# HMAC key for signing OAuth state (32+ random bytes). Required.
SESSION_SECRET=

# GitHub personal access token. Scopes: read:org, public_repo (or repo). Required.
GITHUB_TOKEN=
# Organization whose repos are pulled (e.g. databox). Required.
GITHUB_ORG=
# Databox dataset id for the GitHub repos dataset. Required.
GITHUB_REPOS_DATASET_ID=

# Spotify OAuth2 app credentials. Required.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must match the redirect URI registered on the Spotify app
# (e.g. http://127.0.0.1:3000/api/oauth/spotify/callback). Required.
SPOTIFY_REDIRECT_URI=
# Obtained once via GET /api/oauth/spotify/start → /callback, then pasted here.
SPOTIFY_REFRESH_TOKEN=
# Databox dataset id for the Spotify top-tracks dataset. Required.
SPOTIFY_TOP_TRACKS_DATASET_ID=
# Databox dataset id for the optional Spotify made-for-you dataset.
# SPOTIFY_MADE_FOR_YOU_DATASET_ID=
